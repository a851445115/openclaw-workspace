#!/usr/bin/env python3
import argparse
import json
import os
import sys


SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
LIB_DIR = os.path.join(SCRIPT_DIR, "lib")
if LIB_DIR not in sys.path:
    sys.path.insert(0, LIB_DIR)

import milestones


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser()
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_set = sub.add_parser("set")
    p_set.add_argument("--root", required=True)
    p_set.add_argument("--task-id", required=True)
    p_set.add_argument("--message", required=True)
    p_set.add_argument("--actor", default="orchestrator")

    p_show = sub.add_parser("show")
    p_show.add_argument("--root", required=True)
    p_show.add_argument("--task-id", required=True)

    p_clear = sub.add_parser("clear")
    p_clear.add_argument("--root", required=True)
    p_clear.add_argument("--task-id", required=True)
    p_clear.add_argument("--actor", default="orchestrator")
    return parser


def cmd_set(args: argparse.Namespace) -> int:
    intervention = milestones.set_task_intervention(
        args.root,
        args.task_id,
        args.message,
        actor=args.actor,
    )
    ok = bool(intervention)
    print(
        json.dumps(
            {
                "ok": ok,
                "cmd": "set",
                "taskId": str(args.task_id),
                "intervention": intervention,
            },
            ensure_ascii=True,
        )
    )
    return 0 if ok else 1


def cmd_show(args: argparse.Namespace) -> int:
    intervention = milestones.get_task_intervention(args.root, args.task_id)
    print(
        json.dumps(
            {
                "ok": True,
                "cmd": "show",
                "taskId": str(args.task_id),
                "active": bool(intervention),
                "intervention": intervention,
            },
            ensure_ascii=True,
        )
    )
    return 0


def cmd_clear(args: argparse.Namespace) -> int:
    cleared = milestones.clear_task_intervention(args.root, args.task_id)
    print(
        json.dumps(
            {
                "ok": True,
                "cmd": "clear",
                "taskId": str(args.task_id),
                "cleared": bool(cleared.get("cleared")),
                "actor": str(args.actor),
                "intervention": cleared.get("intervention") if isinstance(cleared.get("intervention"), dict) else {},
            },
            ensure_ascii=True,
        )
    )
    return 0


def main() -> int:
    args = build_parser().parse_args()
    if args.cmd == "set":
        return cmd_set(args)
    if args.cmd == "show":
        return cmd_show(args)
    if args.cmd == "clear":
        return cmd_clear(args)
    raise SystemExit(f"unknown command: {args.cmd}")


if __name__ == "__main__":
    raise SystemExit(main())
